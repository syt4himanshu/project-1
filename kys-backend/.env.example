PORT=5002
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL=postgresql://himanshumire@localhost:5432/sky_db
SECRET_KEY=change-this-secret
JWT_SECRET_KEY=change-this-jwt-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_ORIGIN=
ALLOW_LOCAL_DEV_ORIGINS=true
FORCE_HTTPS=false

# Database Configuration
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2

# Logging Configuration
# Options: debug, info, warn, error
LOG_LEVEL=info

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Groq AI Configuration (optional for core auth/API startup)
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Reliability Configuration (Optional - defaults shown)
# RETRY_MAX_ATTEMPTS=3
# RETRY_INITIAL_DELAY=1000
# RETRY_MAX_DELAY=5000
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
# CIRCUIT_BREAKER_TIMEOUT=30000
# REQUEST_TIMEOUT_STANDARD=30000
# REQUEST_TIMEOUT_EXTENDED=60000
