# Optional explicit API origin.
# Leave blank to use same-origin requests with the Vite `/api` proxy in development.
# Example:
# VITE_API_URL=http://localhost:5003

# Optional dev-only proxy target used by `vite.config.ts`.
# Change this if your backend listens on a different host/port.
# VITE_DEV_API_PROXY_TARGET=http://localhost:5003